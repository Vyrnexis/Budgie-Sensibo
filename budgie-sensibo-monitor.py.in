#!/usr/bin/env python3

import requests
import threading
import gi

gi.require_version('Budgie', '@BUDGIE_GI_VERSION@')
gi.require_version('Gtk', '3.0')
from gi.repository import Budgie, GObject, Gtk, Gio, GLib, Gdk


SERVER = 'https://home.sensibo.com/api/v2'
SETTINGS_SCHEMA = 'com.solus-project.budgie-sensibo-monitor'
REQUEST_TIMEOUT = 10


class SensiboClientAPI:
    def __init__(self, api_key, timeout=REQUEST_TIMEOUT):
        self._api_key = api_key
        self._timeout = timeout

    def _get(self, path, **params):
        params['apiKey'] = self._api_key
        response = requests.get(SERVER + path, params=params, timeout=self._timeout)
        response.raise_for_status()
        return response.json()

    def _patch(self, path, payload, **params):
        params['apiKey'] = self._api_key
        response = requests.patch(SERVER + path, params=params, json=payload, timeout=self._timeout)
        response.raise_for_status()
        return response.json()

    def pod_measurement(self, podUid):
        result = self._get("/pods/%s/measurements" % podUid)
        return result['result']

    def pod_ac_state(self, podUid):
        result = self._get("/pods/%s/acStates" %
                           podUid, limit=1, fields="status,reason,acState")
        return result['result'][0]['acState']

    def pod_change_ac_state(self, podUid, currentAcState, propertyToChange, newValue):
        self._patch("/pods/%s/acStates/%s" % (podUid, propertyToChange),
                    {'currentAcState': currentAcState, 'newValue': newValue})


class BudgieSensiboMonitor(GObject.GObject, Budgie.Plugin):
    """ This is simply an entry point into your Budgie Applet implementation.
        Note you must always override Object, and implement Plugin.
    """

    # Good manners, make sure we have unique name in GObject type system
    __gtype_name__ = "budgie-sensibo-monitor"

    def __init__(self):
        """ Initialisation is important.
        """
        GObject.Object.__init__(self)

    def do_get_panel_widget(self, uuid):
        """ This is where the real fun happens. Return a new Budgie.Applet
            instance with the given UUID. The UUID is determined by the
            BudgiePanelManager, and is used for lifetime tracking.
        """
        return BudgieSensiboMonitorApplet(uuid)


class BudgieSensiboMonitorSettings(Gtk.Grid):
    def __init__(self, settings):
        super().__init__(row_spacing=6, column_spacing=6)
        self.set_margin_top(6)
        self.set_margin_bottom(6)
        self.set_margin_start(6)
        self.set_margin_end(6)

        self.settings = settings
        if self.settings is None:
            self.settings = Gio.Settings(schema=SETTINGS_SCHEMA)

        # API Key
        self.attach(Gtk.Label("API Key:", halign=Gtk.Align.END), 0, 0, 1, 1)
        api_entry = Gtk.Entry()
        api_entry.set_width_chars(30)
        api_entry.set_text(self.settings.get_string("apikey"))
        self.attach(api_entry, 1, 0, 1, 1)
        self.settings.bind("apikey", api_entry, "text", Gio.SettingsBindFlags.DEFAULT)

        # Device ID
        self.attach(Gtk.Label("Device ID:", halign=Gtk.Align.END), 0, 1, 1, 1)
        device_entry = Gtk.Entry()
        device_entry.set_width_chars(30)
        device_entry.set_text(self.settings.get_string("deviceid"))
        self.attach(device_entry, 1, 1, 1, 1)
        self.settings.bind("deviceid", device_entry, "text", Gio.SettingsBindFlags.DEFAULT)

        # Refresh Interval
        self.attach(Gtk.Label("Refresh Interval (minutes):", halign=Gtk.Align.END), 0, 2, 1, 1)
        interval_spin = Gtk.SpinButton.new_with_range(1, 120, 1)
        interval_spin.set_value(self.settings.get_int("intervals"))
        interval_spin.connect("value-changed", self.on_interval_changed)
        self.attach(interval_spin, 1, 2, 1, 1)

        self.show_all()

    def on_interval_changed(self, spin):
        self.settings.set_int("intervals", spin.get_value_as_int())



class BudgieSensiboMonitorApplet(Budgie.Applet):
    """ Budgie.Applet is in fact a Gtk.Bin """
    def __init__(self, uuid):

        Budgie.Applet.__init__(self)
        # Settings
        self.uuid = uuid
        self.settings = Gio.Settings(schema=SETTINGS_SCHEMA)

        # Set API key and device Id from settings
        self.apikey = ''
        self.deviceid = ''
        self.refresh_interval = 60
        self.client = None
        self.ac_state = None
        self.manager = None
        self._destroyed = False
        self._power_change_in_progress = False
        self._update_in_progress = False
        self._syncing_switch = False
        self._refresh_source_id = None
        self._settings_signal_id = None

        self._load_settings()

        # Create Gtk image and set an "off" state icon
        self.icon = Gtk.Image()
        self.icon.set_from_icon_name("sensibo-monitor-icon", Gtk.IconSize.MENU)

        # Create a Grid to hold the components
        self.menugrid = Gtk.Grid()
        self.menugrid.set_row_spacing(5)
        self.menugrid.set_column_spacing(20)

        # left space
        self.menugrid.attach(Gtk.Label("   "), 0, 0, 1, 1)

        # Sensibo data
        self.statslabel = Gtk.Label('Temperature: --' + '\nHumidity: --', xalign=0)
        self.menugrid.attach(self.statslabel, 1, 1, 1, 1)

        # A switch to turn on & off your device ID
        self.switch = Gtk.Switch()
        self.switch.connect("notify::active", self.on_switch_activated)
        self.switch.set_active(False)
        self.menugrid.attach(self.switch, 1, 2, 1, 1)

        # end spacer
        spacer_end = Gtk.Label("")
        self.menugrid.attach(spacer_end, 3, 10, 1, 1)

        # Create the panel applet and popover
        self.box = Gtk.EventBox()
        self.box.add(self.icon)
        self.add(self.box)
        self.popover = Budgie.Popover.new(self.box)
        self.popover.add(self.menugrid)
        self.popover.get_child().show_all()
        self.box.show_all()
        self.show_all()
        self.box.connect("button-press-event", self.on_press)

        self._settings_signal_id = self.settings.connect("changed", self.on_settings_changed)
        self.connect("destroy", self.on_destroy)
        self._schedule_refresh()
        self.refresh()

    def _load_settings(self):
        self.apikey = self.settings.get_string('apikey').strip()
        self.deviceid = self.settings.get_string('deviceid').strip()
        self.refresh_interval = max(60, self.settings.get_int('intervals') * 60)
        self.client = SensiboClientAPI(self.apikey) if self.is_configured() else None

    def is_configured(self):
        return bool(self.apikey and self.deviceid)

    def _schedule_refresh(self):
        if self._refresh_source_id is not None:
            GLib.source_remove(self._refresh_source_id)
        self._refresh_source_id = GLib.timeout_add_seconds(self.refresh_interval, self.refresh)

    def on_settings_changed(self, settings, key):
        self._load_settings()
        if key == 'intervals':
            self._schedule_refresh()
        self.refresh()

    def on_destroy(self, widget):
        self._destroyed = True
        if self._refresh_source_id is not None:
            GLib.source_remove(self._refresh_source_id)
            self._refresh_source_id = None
        if self._settings_signal_id is not None:
            self.settings.disconnect(self._settings_signal_id)
            self._settings_signal_id = None

    def refresh(self):
        if self._destroyed:
            return False

        if not self.is_configured():
            self.statslabel.set_text("Configure API key and device ID")
            self._set_switch_active(False)
            self.icon.set_from_icon_name("sensibo-monitor-icon", Gtk.IconSize.MENU)
            return True

        if self._update_in_progress:
            return True

        self._update_in_progress = True
        threading.Thread(target=self._fetch_state, args=(self.client, self.deviceid), daemon=True).start()
        return True

    def _fetch_state(self, client, deviceid):
        try:
            measurements = client.pod_measurement(deviceid)
            ac_state = client.pod_ac_state(deviceid)
        except Exception as error:
            GLib.idle_add(self._finish_refresh_error, "Failed to load Sensibo data: %s" % error)
            return

        GLib.idle_add(self._apply_state, measurements, ac_state)

    def _finish_refresh_error(self, message):
        self._update_in_progress = False
        return self._show_message(message)

    def _show_message(self, message):
        if not self._destroyed:
            self.statslabel.set_text(message)
        return False

    def _apply_state(self, measurements, ac_state):
        self._update_in_progress = False
        if self._destroyed:
            return False

        self.ac_state = ac_state
        self.statslabel.set_text(self._format_measurement(measurements))
        ac_on = bool(ac_state.get('on'))
        self.icon.set_from_icon_name("sensibo-monitor-icon-on" if ac_on else "sensibo-monitor-icon", Gtk.IconSize.MENU)
        self._set_switch_active(ac_on)
        return False

    def _format_measurement(self, measurements):
        if not measurements:
            return "Temperature: --\nHumidity: --"

        measurement = measurements[0]
        temperature = measurement.get('temperature', '--')
        humidity = measurement.get('humidity', '--')
        return "Temperature: %s°\nHumidity: %s%%" % (temperature, humidity)

    def _set_switch_active(self, active):
        self._syncing_switch = True
        self.switch.set_active(active)
        self._syncing_switch = False

    def on_switch_activated(self, switch, gparam):
        if self._syncing_switch:
            return

        if self._power_change_in_progress:
            self._set_switch_active(bool(self.ac_state and self.ac_state.get('on')))
            return

        ac_on = switch.get_active()
        self.icon.set_from_icon_name("sensibo-monitor-icon-on" if ac_on else "sensibo-monitor-icon", Gtk.IconSize.MENU)

        if not self.is_configured() or self.ac_state is None:
            self.statslabel.set_text("Waiting for Sensibo state")
            self._set_switch_active(False)
            return

        self._power_change_in_progress = True
        self.switch.set_sensitive(False)
        threading.Thread(target=self._change_power_state, args=(self.client, self.deviceid, dict(self.ac_state), ac_on), daemon=True).start()

    def _change_power_state(self, client, deviceid, ac_state, ac_on):
        try:
            client.pod_change_ac_state(deviceid, ac_state, "on", ac_on)
        except Exception as error:
            GLib.idle_add(self._finish_power_error, "Failed to update AC state: %s" % error)
            return

        GLib.idle_add(self._finish_power_change, ac_on)

    def _finish_power_error(self, message):
        self._power_change_in_progress = False
        if not self._destroyed:
            self.switch.set_sensitive(True)
            self._set_switch_active(bool(self.ac_state and self.ac_state.get('on')))
        return self._show_message(message)

    def _finish_power_change(self, ac_on):
        if self._destroyed:
            return False

        self._power_change_in_progress = False
        self.switch.set_sensitive(True)
        if self.ac_state is not None:
            self.ac_state['on'] = ac_on
        self.icon.set_from_icon_name("sensibo-monitor-icon-on" if ac_on else "sensibo-monitor-icon", Gtk.IconSize.MENU)
        self._set_switch_active(ac_on)
        return False

    def on_press(self, box, arg):
        if self.manager is None:
            return Gdk.EVENT_PROPAGATE
        self.manager.show_popover(self.box)
        return Gdk.EVENT_STOP

    def do_update_popovers(self, manager):
        self.manager = manager
        self.manager.register_popover(self.box, self.popover)

    def do_get_settings_ui(self):
        """Return the applet settings with given uuid"""
        return BudgieSensiboMonitorSettings(self.settings)

    def do_supports_settings(self):
        """Return True if support setting through Budgie Setting,
        False otherwise.
        """
        return True
